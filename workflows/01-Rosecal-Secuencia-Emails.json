                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-pendiente",
      "name": "¿Estado = Pendiente?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 100]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.estado }}",
              "rightValue": "email1_enviado",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "cond-2",
              "leftValue": "={{ DateTime.now().diff(DateTime.fromISO($json.fecha_ultimo_contacto), 'days').days }}",
              "rightValue": 6,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-email1",
      "name": "¿Email 1 + 6 dias?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.estado }}",
              "rightValue": "email2_enviado",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "cond-2",
              "leftValue": "={{ DateTime.now().diff(DateTime.fromISO($json.fecha_ultimo_contacto), 'days').days }}",
              "rightValue": 7,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
